# Data source: 'mock' uses in-memory data, 'drizzle' uses real SQL Server
DATA_SOURCE=mock

# Server port
PORT=3001

# CORS origin — must match the Next.js dev server URL
CORS_ORIGIN=http://localhost:3000

# SQL Server connection (only required when DATA_SOURCE=drizzle)
# DB_SERVER=your-sql-server.database.windows.net
# DB_PORT=1433
# DB_NAME=your-database
# DB_USER=your-username
# DB_PASSWORD=your-password
